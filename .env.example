MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=sim-finder
# Optional source DB name for one-time migration into MONGODB_DB_NAME
MONGODB_SOURCE_DB_NAME=blog_views

# Website-only search gate (first N searches free, then short-link redirect)
SHORTLINK_GATE_ENABLED=true
SHORTLINK_GATE_FREE_QUERIES=3
SHORTLINK_UNLOCK_SECRET=replace_with_a_long_random_secret
# Public base URL used in short-link destination (recommended for local testing)
SHORTLINK_REDIRECT_BASE_URL=https://your-domain.com

# Backend search API base (website proxy target)
SEARCH_API_BASE_URL=https://sim-db-backend.vercel.app

# Short-link providers (set your own keys)
SHORTLINK_CUTY_API_KEY=your_cuty_api_key
SHORTLINK_GPLINKS_API_KEY=your_gplinks_api_key
SHORTLINK_EXE_API_KEY=your_exe_api_key
SHORTLINK_SHRINKEARN_API_KEY=your_shrinkearn_api_key

# Optional provider endpoint overrides
SHORTLINK_CUTY_ENDPOINT=https://cuty.io/api
SHORTLINK_GPLINKS_ENDPOINT=https://api.gplinks.com/api
SHORTLINK_EXE_ENDPOINT=https://exe.io/api
SHORTLINK_SHRINKEARN_ENDPOINT=https://shrinkearn.com/api
NEXT_PUBLIC_SITE_URL=https://your-domain.com
